        "description": "Example: Next.js, Tailwind, or Python",
        "name": "title",
        "type": "string",
        "title": "Skill Name"
      },
      {
        "options": {
          "hotspot": true
        },
        "description": "Upload a PNG or SVG logo for this skill",
        "name": "icon",
        "type": "image",
        "title": "Skill Icon"
      },
      {
        "options": {
          "list": [
