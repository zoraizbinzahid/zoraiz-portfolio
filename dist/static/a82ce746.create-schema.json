            },
            {
              "title": "Tools",
              "value": "tools"
            }
          ]
        },
        "name": "category",
        "type": "string"
      }
    ],
    "name": "skill",
    "type": "document"
  },
  {
    "fields": [
      {
        "name": "name",
        "type": "string",
